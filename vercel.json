{
  "redirects": [
    { "source": "/פוסטים-אחרונים-2", "destination": "/post", "permanent": true },
    { "source": "/פוסטים-אחרונים", "destination": "/post", "permanent": true },
    { "source": "/(.+)/", "destination": "/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/wp-content/(.*)", "destination": "https://wp.sod1820.co.il/wp-content/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
