{
  "redirects": [
    { "source": "/פוסטים-אחרונים-2", "destination": "/post", "permanent": true },
    { "source": "/פוסטים-אחרונים", "destination": "/post", "permanent": true },
    { "source": "/דף-ראשי-2", "destination": "/", "permanent": true },
    { "source": "/דף-ראשי", "destination": "/", "permanent": true },
    { "source": "/(.+)/", "destination": "/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/wp-admin", "destination": "/api/honeypot" },
    { "source": "/wp-admin/(.*)", "destination": "/api/honeypot" },
    { "source": "/wp-login.php", "destination": "/api/honeypot" },
    { "source": "/wp-cron.php", "destination": "/api/honeypot" },
    { "source": "/wp-includes/(.*)", "destination": "/api/honeypot" },
    { "source": "/wp-content/(.*)", "destination": "/api/honeypot" },
    { "source": "/xmlrpc.php", "destination": "/api/honeypot" },
    { "source": "/.env", "destination": "/api/honeypot" },
    { "source": "/phpinfo.php", "destination": "/api/honeypot" },
    { "source": "/admin/(.*)", "destination": "/api/honeypot" },
    {
      "source": "/(.*)",
      "has": [{ "type": "header", "key": "user-agent", "value": ".*(facebookexternalhit|Facebot|Twitterbot|WhatsApp|TelegramBot|LinkedInBot|Slackbot|Discordbot|Pinterest|redditbot|Applebot|SkypeUriPreview|vkShare|Embedly|Iframely|W3C_Validator).*" }],
      "destination": "/api/og?path=/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
